# Server-only. Configure in Netlify: Project configuration > Environment variables.
# Do NOT prefix this with VITE_, otherwise it may be exposed to browser code.
MODELSLAB_API_KEY=your_modelslab_api_key

# Optional server-only override if ModelsLab changes the Lustify V8 model identifier.
MODELSLAB_LUSTIFY_MODEL_ID=lustify-sdxl-nsfw-checkpoint-olt-fixed-textures-1768513751
